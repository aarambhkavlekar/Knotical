<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login | Knotical</title>
    <link rel="stylesheet" href="/css/styles.css">
    <style>
        .auth-wrapper { height: 100vh; display: flex; align-items: center; justify-content: center; background: #ece9e2; }
        .auth-card { background: white; padding: 40px; border-radius: 8px; width: 100%; max-width: 400px; box-shadow: 0 4px 20px rgba(0,0,0,0.05); text-align: center; }
        .auth-card h2 { margin-bottom: 20px; letter-spacing: 2px; }
        .auth-card input { width: 100%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 4px; box-sizing: border-box; }
        .auth-btn { width: 100%; padding: 12px; background: #212a2f; color: white; border: none; font-weight: 700; cursor: pointer; margin-top: 10px; }
    </style>
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card">
            <h2>LOGIN</h2>
            <form action="/login" method="POST">
                <input type="email" name="email" placeholder="Email Address" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit" class="auth-btn">SIGN IN</button>
            </form>
            <p style="font-size: 12px; margin-top: 20px;">New to Knotical? <a href="/signup">Create an Account</a></p>
        </div>
    </div>
</body>
</html>