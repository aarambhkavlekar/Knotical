<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Men's Collection | Knotical</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body class="collection-page">
    <nav class="floating-nav">
        <div class="logo"><a href="/">
        <img src="/images/banner.png" alt="Knotical Logo" width="74" height="50">
    </a></div>
        <div class="nav-links">
            <a href="/men">MEN</a>
            <a href="/women">WOMEN</a>
            <a href="/sales">SALE</a>
        </div>
        <div class="nav-icons">
            <a href="#" class="about-link">About</a>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
              <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
            </svg>
            <% if(user){ %>

            <div id="profile-btn" class="profile-btn">

                <svg xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="black"
                    class="bi bi-person"
                    viewBox="0 0 16 16">

                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/>

                </svg>

            </div>

        <% } else { %>

            <a href="/login">

                <svg xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    fill="black"
                    class="bi bi-person"
                    viewBox="0 0 16 16">

                    <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/>

                </svg>

            </a>

        <% } %>
            <span id="cart-btn">🛒</span>
        </div>
    </nav>

    <main class="collection-container">
        <div class="collection-grid">
            <% products.forEach(item => { %>
                <div class="collection-card" onclick="window.location.href='/product/<%= item.id %>'" style="cursor: pointer;">
                    <div class="card-image-box">
                        <% if(item.tag) { %><span class="grid-badge"><%= item.category %></span><% } %>
                        <img src="<%= item.img_url %>" alt="<%= item.name %>">
                    </div>
                    <div class="card-details">
                        <h4 class="grid-name"><%= item.name %></h4>
                        <p class="grid-color"><%= item.color %></p>
                        
                        <% if (item.stock_quantity < 10 && item.stock_quantity > 0) { %>
                            <p style="color: #d97706; font-size: 11px; font-weight: bold; margin-bottom: 5px;">Only <%= item.stock_quantity %> left!</p>
                        <% } else if (item.stock_quantity === 0) { %>
                            <p style="color: #dc2626; font-size: 11px; font-weight: bold; margin-bottom: 5px;">Out of Stock</p>
                        <% } %>

                        <div class="grid-footer">
                            <div class="swatch-row">
                                <% item.hex_colors.forEach(hex => { %>
                                    <div class="mini-swatch" style="background-color: <%= hex %>;"></div>
                                <% }) %>
                                <span class="extra-count">+<%= Math.floor(Math.random() * 10) %></span>
                            </div>
                            <span class="grid-price"><%= item.price %>rs</span>
                        </div>
                    </div>
                </div>
            <% }) %>

            <div class="collection-card promo-card">
                <div class="promo-content">
                    <h3>30% Off Your Order When You Spend $130+</h3>
                </div>
            </div>
        </div>
    </main>
    <%- include('partials/cartDrawer') %>
    <%- include('partials/cartDrawer') %>

<% if(user){ %>

<div id="profile-popup" class="profile-popup">

    <div class="profile-header">

        <div class="profile-avatar">
            <%= user.full_name.charAt(0) %>
        </div>

        <div>
            <h4><%= user.full_name %></h4>
            <p><%= user.email %></p>
        </div>

    </div>

    <div class="profile-links">

        <a href="/profile">My Profile</a>
        <a href="/orders">Orders</a>
        <a href="/wishlist">Wishlist</a>

        <a href="/logout" class="logout-link">
            Logout
        </a>

    </div>

</div>

<% } %>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="/js/main.js"></script>
</body>
</html>